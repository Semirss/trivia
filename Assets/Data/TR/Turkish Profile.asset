    questionText:
      en: You finished drinking your Turkish Coffee. What do you do immediately?
      native: "T\xFCrk Kahveni i\xE7tin, bitti. Hemen ne yapars\u0131n?"
    questionVisual: {fileID: 2800000, guid: 887f1543d90e7e24aa0780e427f6f1ee, type: 3}
    answer0:
